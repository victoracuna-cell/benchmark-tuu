# Streamlit Cloud → Settings → Secrets

GITHUB_TOKEN          = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GITHUB_REPO           = "tu-usuario/tu-repo"
GITHUB_PATH           = "data/benchmark.json"

# Browserless — browserless.io (renderiza JavaScript completo)
BROWSERLESS_API_KEY   = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Tavily — fallback de emergencia (opcional pero recomendado)
TAVILY_API_KEY        = "tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Groq — estructura los datos con Llama 3
GROQ_API_KEY          = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
